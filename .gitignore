# Python caches and artifacts
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Generated PyTorch exports (created by `lake exe torchlean pytorch_roundtrip --action export`)
NN/Examples/PyTorch/*/Test*.py
NN/Examples/Interop/PyTorch/*/Test*.py

# PINN training artifacts
NN/Examples/Verification/PINN/checkpoints/
*.pt

# Verification experiment outputs. Small checked-in JSON artifacts live next to examples, but new
# generated artifacts should go into these ignored directories or `_external/`.
NN/Examples/Verification/**/generated/
NN/Examples/Verification/**/outputs/
NN/Examples/Verification/TwoStageTorchLean/_external/
blueprint/print/*.nfs*

# LaTeX build artifacts (paper/blueprint)
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.paux
*.synctex.gz
*.toc
missfont.log

# Verso output (generated HTML/book assets)
/_out/
/docs/manual/
**/_out/
verso_manual/.verso/
verso_manual/.lake/

# Local experiment repos / scratchpads (not part of the public TorchLean library)
/disabled
testingoblass/
pdf/
plots/

# Repo tooling (note: existing tracked files are still public; this only ignores *new* untracked artifacts).
tools/

# Optional external experiment repo (keep it out of the public repo).
# If you work on it locally, clone it into the repo root and it will stay untracked.
PINN_verification/
Two-Stage_Neural_Controller_Training/

# Jekyll / GitHub Pages site build artifacts
home_page/_site/
home_page/.jekyll-cache/
home_page/.sass-cache/
home_page/.jekyll-metadata
home_page/docs/
home_page/manual/
home_page/blueprint/
home_page/blueprint

# Bundler installs (avoid committing Ruby gems)
home_page/vendor/
home_page/.bundle/
.bundle/
vendor/bundle/

# Local installers / large downloads
Miniconda3-*.sh

# Blueprint build outputs (generated by `leanblueprint pdf|web`)
# Sources live in `blueprint/src/`; CI rebuilds outputs and deploys via GitHub Pages.
blueprint/print/
blueprint/web/

# Benchmark profiler outputs
benchmark/out/
